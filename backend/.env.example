# App
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# PostgreSQL + PostGIS
DB_HOST=localhost
DB_PORT=5432
DB_USER=fsm_user
DB_PASSWORD=fsm_password
DB_NAME=fsm_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change_this_to_a_strong_random_secret_256bits
JWT_EXPIRATION=7d

# Routing Engine (OSRM public demo — substitua por instância própria em prod)
OSRM_BASE_URL=http://router.project-osrm.org

# WhatsApp (Evolution API)
WHATSAPP_API_URL=http://localhost:8080
WHATSAPP_API_KEY=your_evolution_api_key
WHATSAPP_INSTANCE=fsm_instance

# Mapbox (Geocodificação)
MAPBOX_ACCESS_TOKEN=pk.your_mapbox_token

# Tracking page base URL (enviado ao cliente via WhatsApp)
TRACKING_BASE_URL=https://track.seudominio.com.br
